local function buildblock(pos, bsize)
    task.wait(0.01)
    built, skipblock = false, false
    local attempts = 0
    repeat
        attempts += 1
        forceEquip("Build")
        local event = getToolEvent("Build")
        if event then
            event:FireServer(Workspace.Terrain, Enum.NormalId.Top, pos, bsize or "normal")
        end
        if tpToBlock then
            local hrp = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if hrp then hrp.CFrame = CFrame.new(pos + Vector3.new(0, 6, 0)) end
        end
        task.wait(0.07)
    until built or stopped or skipblock or attempts > 40
    built = false
end

